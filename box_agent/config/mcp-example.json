{
    "mcpServers": {
        "tavily": {
            "description": "Tavily - Web search and content extraction",
            "url": "https://mcp.tavily.com/mcp/?tavilyApiKey=YOUR_API_KEY",
            "type": "streamable_http",
            "disabled": true
        },
        "memory": {
            "description": "Memory - Knowledge graph memory system (long-term memory based on graph database)",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-memory"
            ],
            "disabled": true
        },
        "playwright": {
            "description": "Playwright - Browser automation (Chromium). Run `box-agent install-browser` first.",
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest"
            ],
            "disabled": true,
            "connect_timeout": 15.0,
            "execute_timeout": 60.0
        }
    }
}